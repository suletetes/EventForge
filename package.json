{
  "name": "eventforge",
  "version": "1.0.0",
  "private": true,
  "description": "EventForge - Hybrid event processing platform with ECS Fargate and Lambda",
  "workspaces": [
    "packages/api",
    "packages/lambdas",
    "packages/shared",
    "packages/frontend",
    "packages/infra"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'packages/*/src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx,json}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx,json}'"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "fast-check": "^3.19.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.2"
  }
}
